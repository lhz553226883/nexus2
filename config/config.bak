# 全局 LLM 配置（阿里通义千问）
[llm]
api_type = "openai"  # 核心：保持 openai 兼容模式
model = "qwen3.5-plus-2026-02-15"  # 阿里模型名（如 qwen-turbo/qwen-plus/qwen-max-0428）
base_url = "https://dashscope.aliyuncs.com/compatible-mode/v1"  # 阿里 OpenAI 兼容接口地址
api_key = "sk-ceee0497da05422dae835e2c8bf00772"  # 替换为你的阿里云 DashScope API 密钥
max_tokens = 8192  # 阿里模型支持的最大 tokens（按需调整）
temperature = 0.0  # 随机性控制

# 视觉模型（若需多模态，如通义千问视觉版）
[llm.vision]
api_type = "openai"
model = "qwen3-vl-plus-2025-12-19"  # 阿里多模态模型名
base_url = "https://dashscope.aliyuncs.com/compatible-mode/v1"
api_key = "sk-ceee0497da05422dae835e2c8bf00772"  # 同上文的 API 密钥
max_tokens = 8192
temperature = 0.0

# Daytona 配置（必填，即使不用也要声明）
[daytona]
daytona_api_key = ""
daytona_base_url = "https://api.daytona.io"
enable = false  # 关键：关闭该功能，避免校验失败

# Global LLM configuration 
